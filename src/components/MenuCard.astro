---
interface Props {
  title:       string;
  category:    string;
  price:       string;
  description: string;
  image:       string;
  featured:    boolean;
}

const { title, category, price, description, image, featured } = Astro.props;
---

<article class="bg-bakery-cream rounded-2xl overflow-hidden border border-bakery-linen shadow-sm hover:shadow-md transition-shadow duration-300 flex flex-col">
  <div class="relative">
    <img src={image} alt={title} class="w-full h-48 object-cover" />
    {featured && (
      <span class="absolute top-3 right-3 bg-bakery-green text-bakery-cream text-xs font-medium px-3 py-1 rounded-full">
        Featured
      </span>
    )}
  </div>

  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-center justify-between mb-3">
      <span class="bg-bakery-linen text-bakery-green text-xs font-medium px-3 py-1 rounded-full">
        {category}
      </span>
      <span class="font-serif text-bakery-ochre font-semibold text-lg">{price}</span>
    </div>
    <h3 class="font-serif text-bakery-brown text-xl font-semibold mb-2">{title}</h3>
    <p class="text-bakery-brown/70 text-sm leading-relaxed flex-1">{description}</p>
    <button
      class="add-to-cart-btn mt-4 w-full bg-bakery-green text-bakery-cream py-2.5 rounded-full text-sm font-medium transition-colors duration-300 hover:bg-bakery-amber"
      data-title={title}
      data-price={price}
    >
      + Add to Order
    </button>
  </div>
</article>
